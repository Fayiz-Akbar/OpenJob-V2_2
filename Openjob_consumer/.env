# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
HOST=localhost

# ==========================================
# DATABASE CONFIGURATION (POSTGRESQL)
# ==========================================
PGUSER=postgres
PGHOST=localhost
PGPASSWORD=PostgreFayiz2662
PGDATABASE=openjob_db
PGPORT=5432
DATABASE_URL=postgres://postgres:PostgreFayiz2662@localhost:5432/openjob_db

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Silakan ganti dengan string acak/secret key yang panjang dan aman
ACCESS_TOKEN_KEY=bikin_secret_key_access_token_bebas_tapi_panjang
REFRESH_TOKEN_KEY=bikin_secret_key_refresh_token_bebas_tapi_panjang
ACCESS_TOKEN_AGE=1h

# ==========================================
# CACHING (REDIS) - Kriteria 2
# ==========================================
# Sesuai instruksi Dicoding, nama variable harus persis seperti ini
REDIS_HOST=localhost

# RabbitMQ (AMQP) Environment Variables
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

